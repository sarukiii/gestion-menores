// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// schema.prisma — Plano completo de la base de datos.
// Cada "model" se convierte en una tabla en PostgreSQL.
// Prisma lee este archivo y genera el código TypeScript para interactuar con la BD.

// Define dónde se genera el cliente TypeScript de Prisma
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Define qué tipo de base de datos usamos
// La URL de conexión va en prisma.config.ts (cambio de Prisma 7)
datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────
// Los enums son listas de valores fijos — la BD solo acepta estos valores exactos

// Roles de los profesionales del equipo
enum Rol {
  MONITOR
  ATE
  EDUCADOR
  TRABAJADOR_SOCIAL
  PSICOLOGO
  COORDINACION
  DIRECCION
}

// Estado posible de la medida judicial del menor
enum EstadoMedida {
  ACTIVA
  SUSPENDIDA
  FINALIZADA
}

// Tipos de informe extraordinario — motivos que pueden alterar la medida
enum TipoExtraordinario {
  SALUD_MENTAL
  CAMBIO_FAMILIAR
  EMBARAZO
  NUEVO_DELITO
  ADICCION
  OTRO
}

// ─── MODELO USUARIO ──────────────────────────────────────────────
// Representa a cada profesional que usa la app

model Usuario {
  // @id — clave primaria de la tabla
  // @default(cuid()) — genera un ID único automáticamente
  id         String   @id @default(cuid())
  nombre     String
  // @unique — no pueden existir dos usuarios con el mismo email
  email      String   @unique
  password   String
  rol        Rol      @default(EDUCADOR)
  // Si está activo o dado de baja sin eliminar el registro
  activo     Boolean  @default(true)
  // @default(now()) — guarda la fecha y hora actual automáticamente
  creadoEn   DateTime @default(now())

  // Relaciones — un usuario puede crear muchos informes de cada tipo
  // Estos campos no son columnas en la BD, son accesos virtuales de Prisma
  informesIniciales      InformeInicial[]
  informesSeguimiento    InformeSeguimiento[]
  informesExtraordinario InformeExtraordinario[]
  informesFinales        InformeFinal[]
  incidencias            Incidencia[]
}

// ─── MODELO MENOR ────────────────────────────────────────────────
// Ficha completa de cada menor en el sistema

model Menor {
  id                  String       @id @default(cuid())

  // Datos personales básicos
  // El ? indica que el campo es opcional — puede estar vacío
  nombre              String
  apellidos           String
  fechaNacimiento     DateTime
  dni                 String?      @unique
  nacionalidad        String?
  domicilio           String?
  telefono            String?

  // Información sobre la medida judicial
  expediente          String       @unique
  tipoMedida          String
  estadoMedida        EstadoMedida @default(ACTIVA)
  fechaInicio         DateTime
  fechaFin            DateTime?
  juzgado             String?

  // Información familiar
  tutorNombre         String?
  tutorTelefono       String?
  tutorRelacion       String?
  situacionFamiliar   String?

  // Situación educativa
  centroEducativo     String?
  cursoNivel          String?
  situacionEscolar    String?

  // Situación de salud física
  medicoAsignado      String?
  centroSalud         String?
  observacionesSalud  String?

  // Situación de salud mental
  psicologoAsignado   String?
  diagnostico         String?
  medicacion          String?

  // Situación con servicios sociales
  trabajadorSocial    String?
  serviciosSociales   String?

  // Perfil psicológico general
  perfilPsicologico   String?

  // Objetivos del plan de intervención educativa
  objetivos_generales   String?
  objetivos_especificos String?

  creadoEn            DateTime @default(now())
  // @updatedAt — se actualiza automáticamente cada vez que se modifica el registro
  actualizadoEn       DateTime @updatedAt

  // Relaciones — un menor puede tener muchos informes e incidencias
  informesIniciales      InformeInicial[]
  informesSeguimiento    InformeSeguimiento[]
  informesExtraordinario InformeExtraordinario[]
  informesFinales        InformeFinal[]
  incidencias            Incidencia[]
}

// ─── INFORME INICIAL ─────────────────────────────────────────────
// Se crea cuando el menor ingresa en el centro

model InformeInicial {
  id                          String   @id @default(cuid())
  fecha                       DateTime @default(now())

  // Situación al ingreso
  motivoIngreso               String
  situacionFamiliarIngreso     String?
  situacionEducativaIngreso    String?
  situacionSaludIngreso        String?
  situacionSaludMentalIngreso  String?
  redSocialApoyo               String?

  // Adicciones y consumo de tóxicos al ingreso
  consumoSustancias            Boolean  @default(false)
  sustanciasConsumidas         String?  // alcohol, cannabis, cocaína...
  frecuenciaConsumo            String?
  edadInicioConsumo            String?
  tratamientoPrevio            Boolean  @default(false)
  observacionesConsumo         String?

  // Valoración inicial del equipo
  valoracionEducativa          String?
  riesgosDetectados            String?
  necesidadesDetectadas        String?
  objetivosInicio              String?
  recursosPlanificados         String?

  // Relación con el menor — @relation conecta esta tabla con la tabla Menor
  // fields: campo de esta tabla | references: campo de la tabla Menor
  menorId                      String
  menor                        Menor    @relation(fields: [menorId], references: [id])

  // Relación con el usuario que redactó el informe
  usuarioId                    String
  usuario                      Usuario  @relation(fields: [usuarioId], references: [id])

  creadoEn                     DateTime @default(now())
}

// ─── INFORME DE SEGUIMIENTO ───────────────────────────────────────
// Se realiza cada 3 meses durante el cumplimiento de la medida

model InformeSeguimiento {
  id                          String   @id @default(cuid())
  fecha                       DateTime @default(now())
  periodo                     String   // ej: "1er trimestre 2025"

  // Evolución por áreas de intervención
  evolucionEducativa          String?
  evolucionFamiliar           String?
  evolucionSalud              String?
  evolucionSaludMental        String?
  evolucionServiciosSociales  String?
  evolucionConducta           String?

  // Evolución en consumo de tóxicos
  evolucionConsumo            String?  // mejora / estable / empeora
  sustanciasActuales          String?
  enTratamientoAdicciones     Boolean  @default(false)
  recursoAdicciones           String?  // nombre del centro o programa
  observacionesConsumo        String?

  // Revisión de objetivos del trimestre
  objetivosConseguidos        String?
  objetivosPendientes         String?
  objetivosNuevos             String?

  // Valoración global y propuesta de continuación
  valoracionGeneral           String?
  propuestaContinuacion       String?

  menorId                     String
  menor                       Menor    @relation(fields: [menorId], references: [id])
  usuarioId                   String
  usuario                     Usuario  @relation(fields: [usuarioId], references: [id])

  creadoEn                    DateTime @default(now())
}

// ─── INFORME EXTRAORDINARIO ──────────────────────────────────────
// Se genera cuando ocurre algo relevante que puede afectar a la medida

model InformeExtraordinario {
  id                    String             @id @default(cuid())
  fecha                 DateTime           @default(now())
  // Tipo de situación extraordinaria usando el enum definido arriba
  tipo                  TipoExtraordinario

  descripcionHecho      String
  impactoEnMedida       String?
  medidasAdoptadas      String?
  // A quién se ha comunicado: juzgado, familia, servicios sociales...
  comunicadoA           String?
  // Si requiere modificación formal de la medida judicial
  requiereModificacion  Boolean            @default(false)

  menorId               String
  menor                 Menor              @relation(fields: [menorId], references: [id])
  usuarioId             String
  usuario               Usuario            @relation(fields: [usuarioId], references: [id])

  creadoEn              DateTime           @default(now())
}

// ─── INFORME FINAL ───────────────────────────────────────────────
// Se redacta cuando el menor finaliza la medida y abandona el centro

model InformeFinal {
  id                       String   @id @default(cuid())
  fecha                    DateTime @default(now())

  // Resumen del proceso completo
  resumenIntervencion      String?
  duracionMedida           String?

  // Balance de objetivos al cierre
  objetivosAlcanzados      String?
  objetivosNoCumplidos     String?

  // Situación en todas las áreas al momento del cierre
  situacionFamiliarCierre  String?
  situacionEducativaCierre String?
  situacionSaludCierre     String?
  redApoyoCierre           String?

  // Situación de consumo al cierre
  situacionConsumoCierre    String?  // abstinente / reducción / sin cambios
  enTratamientoAlCierre     Boolean  @default(false)
  recursoAdiccionesCierre   String?
  observacionesConsumoCierre String?

  // Pronóstico y recursos a los que se deriva al salir
  pronostico               String?
  recomendaciones          String?
  derivaciones             String?

  menorId                  String
  menor                    Menor    @relation(fields: [menorId], references: [id])
  usuarioId                String
  usuario                  Usuario  @relation(fields: [usuarioId], references: [id])

  creadoEn                 DateTime @default(now())
}

// ─── INCIDENCIAS ─────────────────────────────────────────────────
// Registro de incidentes ocurridos durante la estancia

model Incidencia {
  id          String   @id @default(cuid())
  fecha       DateTime @default(now())
  descripcion String
  gravedad    String   // leve / moderada / grave
  // Si la incidencia ha sido resuelta o sigue abierta
  resuelta    Boolean  @default(false)

  menorId     String
  menor       Menor    @relation(fields: [menorId], references: [id])
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
}